{
  "name": "adserver",
  "version": "1.0.0",
  "description": "A modern, scalable ad server for serving and managing digital advertisements",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t adserver .",
    "docker:run": "docker run -p 3000:3000 adserver"
  },
  "keywords": [
    "adserver",
    "advertising",
    "ads",
    "digital-marketing",
    "nodejs",
    "express",
    "api"
  ],
  "author": "AdServer Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "joi": "^17.9.2",
    "rate-limiter-flexible": "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.46.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}